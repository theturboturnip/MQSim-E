ssd := "ssd_config/ssd_C8_P4_64G.xml"

default:
    @just --list

build:
    make

bench n:
    ./MQSim -i {{ssd}} -w workload_config/iocap/synth_{{n}}.xml -o results/iocap-raw/run{{n}} 1>results/iocap-raw/run{{n}}_stdout.txt

bench-all: build
    mkdir -p results/iocap-raw
    just bench 1per
    just bench 2per
    just bench 2per_readonly
    just bench 2per_writeonly
    just bench 4per
    just bench 8per
    just bench 16per
    just bench 16per_readonly
    just bench 16per_writeonly
    just bench 32per
    just bench 64per

report:
    mkdir -p results/iocap
    uv run tomlize_results.py --toml ./results/iocap/mqsim-e-results.toml ./results/iocap-raw/run*.xml
